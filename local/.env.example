# Copy to `.env` (in this local/ folder) and fill in. docker compose reads it.

# Match the container user to your host UID so dbt can write target/ and
# dbt_packages/ into the mounted ../dbt. Run: id -u
AIRFLOW_UID=1000

# GCP / BigQuery
GCP_PROJECT=my-gcp-project
DBT_DATASET=dwh
DBT_LOCATION=asia-southeast1

# Auth is keyless: your host gcloud config (~/.config/gcloud) is mounted in,
# so run this ONCE on the host before `docker compose up`:
#   gcloud auth application-default login
# No keyfile path needed.
